{
  "name": "@aituber/mcp-server",
  "version": "1.7.0",
  "packageManager": "pnpm@9.15.1",
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "path-to-regexp": "8.4.0"
    }
  },
  "description": "AITuber MCP server, hosted at https://mcp.aituber.app. Create AI videos with narration, visuals, and captions for YouTube Shorts, TikTok, and Instagram Reels, and publish them, straight from Claude Desktop, Claude Code, ChatGPT, Codex, Cursor, or OpenClaw.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aituber-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=build/index.js && chmod +x build/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "dev:remote": "wrangler dev",
    "deploy:remote": "wrangler deploy"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-video",
    "ai-video-generator",
    "aituber",
    "video-generation",
    "youtube-shorts",
    "tiktok",
    "instagram-reels",
    "faceless-video",
    "text-to-video",
    "ai-narration",
    "video-automation",
    "content-creation",
    "long-form-video",
    "ai-voices",
    "video-publishing",
    "claude",
    "claude-desktop",
    "cursor",
    "windsurf"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aituberapp/aituber-mcp.git"
  },
  "homepage": "https://aituber.app",
  "bugs": {
    "url": "https://github.com/aituberapp/aituber-mcp/issues"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.5",
    "@hono/mcp": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.0",
    "wrangler": "^4.111.0"
  }
}
